      "body": "<p style='margin:0in 0in 8pt;color:rgb(51, 51, 51);font-family:proxima-nova, \"proxima nova\", \"Helvetica Neue\", Helvetica, Arial, sans-serif;font-style:normal;font-weight:400;letter-spacing:normal;text-indent:0px;text-transform:none;white-space:normal;background-color:rgb(255, 255, 255);line-height:15.9px;font-size:15px;text-align:center;'><span style=\"font-size:21px;line-height:22.26px;color:rgb(56, 86, 35);\">Tomorrow is College Craze Thursday!</span></p><p style='margin:0in 0in 8pt;color:rgb(51, 51, 51);font-family:proxima-nova, \"proxima nova\", \"Helvetica Neue\", Helvetica, Arial, sans-serif;font-style:normal;font-weight:400;letter-spacing:normal;text-indent:0px;text-transform:none;white-space:normal;background-color:rgb(255, 255, 255);line-height:15.9px;font-size:15px;text-align:center;'><span style=\"font-size:21px;line-height:22.26px;color:rgb(255, 192, 0);\">Remember to wear your COLLEGE gear!</span></p><p style='margin:0in 0in 8pt;color:rgb(51, 51, 51);font-family:proxima-nova, \"proxima nova\", \"Helvetica Neue\", Helvetica, Arial, sans-serif;font-style:normal;font-weight:400;letter-spacing:normal;text-indent:0px;text-transform:none;white-space:normal;background-color:rgb(255, 255, 255);line-height:15.9px;font-size:15px;text-align:center;'><span style=\"font-size:21px;line-height:22.26px;\">Teacher Spotlight</span></p><div style=\"text-align:center;\">\n<span style=\"font-size:18px;line-height:22.26px;\">Ms. </span><span style=\"font-size:18px;\">Mankin </span>\n</div><div style=\"border:0px;font-style:normal;font-weight:400;font-size:16px;line-height:inherit;margin:0px;padding:0px;vertical-align:baseline;letter-spacing:normal;text-indent:0px;text-transform:none;background-color:rgb(255, 255, 255);text-align:center;color:black !important;\"><span style=\"font-size:18px;\">Teaches Digital Arts 1 + 2</span></div><div style=\"border:0px;font-style:normal;font-weight:400;font-size:16px;line-height:inherit;margin:0px;padding:0px;vertical-align:baseline;letter-spacing:normal;text-indent:0px;text-transform:none;background-color:rgb(255, 255, 255);text-align:center;color:black !important;\"><span style=\"font-size:18px;\">Attended Corbin University and Laguna College of Art and Design </span></div><div style=\"border:0px;font-style:normal;font-weight:400;font-size:16px;line-height:inherit;margin:0px;padding:0px;vertical-align:baseline;letter-spacing:normal;text-align:center;text-indent:0px;text-transform:none;background-color:rgb(255, 255, 255);color:black !important;\"><span style=\"font-size:18px;\">Fun college memory: Getting to travel to Florida with my college soccer team for the NAIA National Tournament. I got to travel with a team of my best friends and make memories of a lifetime! </span></div><span style=\"font-size:18px;\"><img src=\"https://posts.parentsquare.com/inline_images_9baaebceb3ffbefa_1776889883767-Corban+University.png\" style=\"width:300px;display:block;vertical-align:top;margin:5px auto;text-align:center;\"></span>",
